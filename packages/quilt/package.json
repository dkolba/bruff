{
  "name": "@bruff/quilt",
  "version": "0.0.0",
  "private": true,
  "description": "Development-only frontend tool for creating Bruff game maps.",
  "type": "module",
  "main": "index.ts",
  "scripts": {
    "format": "prettier --write .",
    "lint": "eslint",
    "lint:fix": "eslint . --fix",
    "test:watch": "vitest",
    "test": "pnpm run test:chromium && pnpm run test:firefox && pnpm run test:webkit",
    "test:chromium": "vitest run --browser=chromium --coverage ",
    "test:firefox": "vitest run --browser=firefox",
    "test:webkit": "vitest run --browser=webkit",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@bruff/eslint-config": "workspace:0.0.0",
    "@vitest/browser": "catalog:",
    "@vitest/browser-playwright": "catalog:",
    "@vitest/coverage-v8": "catalog:",
    "eslint": "catalog:",
    "playwright": "catalog:",
    "prettier": "catalog:",
    "typescript": "catalog:",
    "vitest": "catalog:"
  },
  "dependencies": {
    "@bruff/contracts": "workspace:0.0.0",
    "@bruff/utils": "workspace:0.0.0"
  }
}
