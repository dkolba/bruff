{
  "all": true,
  "check-coverage": true,
  "temp-dir": "arcade/.nyc_output",
  "reporter": ["text", "html"],
  "report-dir": "arcade/coverage",
  "extension": [".ts"],
  "include": ["game/lib/**/*.ts", "arcade/app.ts"],
  "exclude": ["game/lib/effects/observable/touch.ts"],
  "branches": 80,
  "lines": 80,
  "functions": 80,
  "statements": 80
}
