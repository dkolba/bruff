{
  "all": true,
  "check-coverage": true,
  "temp-dir": "arcade/.nyc_output",
  "reporter": ["text", "html"],
  "report-dir": "arcade/coverage",
  "extension": [".ts"],
  "include": ["game/lib/**/*.ts", "arcade/app.ts"],
  "exclude": [
    "game/lib/effects/clock.ts",
    "game/lib/effects/frame-step-driver.ts",
    "game/lib/effects/loop.ts",
    "game/lib/effects/observable/keydown.ts",
    "game/lib/effects/observable/touch.ts",
    "game/lib/effects/test-api.ts",
    "game/lib/effects/test-mode.ts"
  ],
  "branches": 80,
  "lines": 80,
  "functions": 80,
  "statements": 80
}
