{
  "name": "@bruff/arcade",
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "coverage:e2e:prune": "rimraf .nyc_instrumented .nyc_output",
    "coverage:e2e:report": "nyc report --cwd=.. --nycrc-path=packages/arcade/.nycrc.json",
    "build": "pnpm run build:site && pnpm run check:bundle-clean",
    "build:site": "vite build --outDir site && pnpm run check:bundle-clean",
    "check:bundle-clean": "node scripts/check-bundle-clean.mjs",
    "dev": "vite",
    "format": "prettier --write .",
    "lint": "eslint",
    "lint:fix": "eslint . --fix",
    "typecheck": "tsc",
    "test:e2e": "playwright test",
    "test:e2e:update-snapshots": "pnpm run test:e2e --grep @snapshot --update-snapshots=all",
    "test": "pnpm run coverage:e2e:prune && pnpm run test:e2e && pnpm run coverage:e2e:report"
  },
  "devDependencies": {
    "@axe-core/playwright": "catalog:",
    "@bruff/eslint-config": "workspace:0.0.0",
    "@bruff/game": "workspace:0.0.0",
    "@bruff/quilt": "workspace:0.0.0",
    "@bruff/sigil": "workspace:0.0.0",
    "@playwright/test": "catalog:",
    "eslint": "catalog:",
    "eslint-plugin-playwright": "catalog:",
    "nyc": "catalog:",
    "playwright": "catalog:",
    "prettier": "catalog:",
    "rimraf": "catalog:",
    "typescript": "catalog:",
    "vite": "catalog:",
    "vite-plugin-istanbul": "catalog:"
  }
}
