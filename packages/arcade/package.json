{
  "name": "@bruff/arcade",
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "coverage:e2e:prune": "rimraf .nyc_instrumented .nyc_output",
    "coverage:e2e:report": "nyc report --cwd=.. --temp-dir=arcade/.nyc_output --reporter=text --reporter=html",
    "build:site": "vite build --outDir site",
    "dev": "vite",
    "format": "prettier --write .",
    "lint": "eslint",
    "typecheck": "tsc",
    "test:e2e": "playwright test",
    "test": "pnpm run coverage:e2e:prune && pnpm run test:e2e && pnpm run coverage:e2e:report"
  },
  "devDependencies": {
    "@axe-core/playwright": "4.11.2",
    "@bruff/eslint-config": "workspace:0.0.0",
    "@bruff/game": "workspace:0.0.0",
    "@playwright/test": "1.59.1",
    "eslint": "10.2.1",
    "eslint-plugin-playwright": "2.10.1",
    "nyc": "18.0.0",
    "playwright": "1.59.1",
    "prettier": "3.8.3",
    "rimraf": "6.1.3",
    "typescript": "5.9.3",
    "vite": "8.0.10",
    "vite-plugin-istanbul": "8.0.0"
  }
}
