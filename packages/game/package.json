{
  "name": "@bruff/game",
  "version": "0.0.0",
  "type": "module",
  "files": [
    "dist",
    "types"
  ],
  "main": "./lib/effects/entry.ts",
  "types": "./types/entry.d.ts",
  "exports": {
    ".": {
      "types": "./types/entry.d.ts",
      "import": "./lib/effects/entry.ts"
    },
    "./headless": {
      "types": "./types/headless.d.ts",
      "bruff-source": "./lib/headless/index.ts",
      "node": "./dist/headless/index.js",
      "import": "./lib/headless/index.ts"
    },
    "./test-api": {
      "types": "./lib/effects/test-api/test-api-types.ts",
      "import": "./lib/effects/test-api/test-api-types.ts"
    }
  },
  "scripts": {
    "build": "pnpm run typecheck && pnpm run build:lib",
    "build:lib": "vite build --config vite.config.lib.js",
    "format": "prettier --write .",
    "lint": "eslint",
    "typecheck": "tsc",
    "test:unit": "pnpm run test:unit:chromium && pnpm run test:unit:firefox && pnpm run test:unit:webkit",
    "test:unit:chromium": "vitest run --browser=chromium --coverage",
    "test:unit:firefox": "vitest run --browser=firefox",
    "test:unit:webkit": "vitest run --browser=webkit",
    "test:unit:watch": "vitest",
    "test": "pnpm run test:unit"
  },
  "devDependencies": {
    "@bruff/eslint-config": "workspace:0.0.0",
    "@bruff/game-element": "workspace:0.0.0",
    "@bruff/utils": "workspace:0.0.0",
    "@fast-check/vitest": "catalog:",
    "@vitest/browser": "catalog:",
    "@vitest/browser-playwright": "catalog:",
    "@vitest/coverage-v8": "catalog:",
    "eslint": "catalog:",
    "observable-polyfill": "catalog:",
    "playwright": "catalog:",
    "prettier": "catalog:",
    "typescript": "catalog:",
    "vite": "catalog:",
    "vite-plugin-istanbul": "catalog:",
    "vitest": "catalog:"
  }
}
