{
  "name": "@bruff/game",
  "version": "0.0.0",
  "type": "module",
  "files": [
    "dist"
  ],
  "main": "./dist/bruff-game.js",
  "types": "dist/bruff-game.d.ts",
  "exports": {
    "types": "./dist/bruff-game.d.ts",
    "import": "./dist/bruff-game.js"
  },
  "scripts": {
    "coverage:e2e:prune": "rimraf .nyc_instrumented .nyc_output",
    "coverage:e2e:report": "nyc report --reporter=text --reporter=html",
    "build": "pnpm run typecheck && pnpm run build:lib",
    "build:lib": "vite build --config vite.config.lib.js",
    "build:site": "pnpm run typecheck && vite build --outDir site",
    "dev": "vite",
    "format": "prettier --write .",
    "lint": "eslint",
    "typecheck": "tsc",
    "test:e2e": "playwright test",
    "test:unit": "pnpm run test:unit:chromium && pnpm run test:unit:firefox && pnpm run test:unit:webkit",
    "test:unit:chromium": "vitest run --browser=chromium --coverage",
    "test:unit:firefox": "vitest run --browser=firefox",
    "test:unit:webkit": "vitest run --browser=webkit",
    "test:unit:watch": "vitest",
    "test": "pnpm run coverage:e2e:prune && pnpm run test:e2e && pnpm run coverage:e2e:report && pnpm run test:unit"
  },
  "devDependencies": {
    "@axe-core/playwright": "4.11.1",
    "@bruff/eslint-config": "workspace:0.0.0",
    "@bruff/utils": "workspace:0.0.0",
    "@playwright/test": "1.59.1",
    "@vitest/browser": "4.1.4",
    "@vitest/browser-playwright": "4.1.4",
    "@vitest/coverage-v8": "4.1.4",
    "eslint": "10.2.0",
    "eslint-plugin-jsdoc": "62.9.0",
    "eslint-plugin-playwright": "2.10.1",
    "eslint-plugin-tsdoc": "0.5.2",
    "nyc": "18.0.0",
    "observable-polyfill": "0.0.29",
    "playwright": "1.59.1",
    "prettier": "3.8.2",
    "rimraf": "6.1.3",
    "typescript": "5.9.3",
    "vite": "8.0.8",
    "vite-plugin-dts": "4.5.4",
    "vite-plugin-istanbul": "8.0.0",
    "vitest": "4.1.4"
  }
}
