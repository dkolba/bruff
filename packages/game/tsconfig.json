{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "baseUrl": ".",
    "composite": true,
    "paths": {
      "@/*": ["lib/*"]
    }
  },
  "include": [
    "lib/**/*.ts",
    "types/**/*.ts",
    "lib/**/*.test.ts",
    "tests/fixtures/**/*.json",
    "tests/snapshots/**/*.json"
  ],
  "exclude": ["node_modules", "eslint.config.js"]
}
