{
  "name": "@bruff/utils",
  "version": "0.0.0",
  "private": true,
  "description": "",
  "type": "module",
  "main": "index.ts",
  "scripts": {
    "format": "prettier --write .",
    "lint": "eslint",
    "test:watch": "vitest",
    "test": "pnpm run test:chromium && pnpm run test:firefox && pnpm run test:webkit",
    "test:chromium": "vitest run --browser=chromium --coverage ",
    "test:firefox": "vitest run --browser=firefox",
    "test:webkit": "vitest run --browser=webkit",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@bruff/eslint-config": "workspace:0.0.0",
    "@types/node": "25.5.0",
    "@vitest/browser": "4.0.18",
    "@vitest/browser-playwright": "4.0.18",
    "@vitest/coverage-v8": "4.0.18",
    "eslint": "9.39.4",
    "playwright": "1.58.2",
    "prettier": "3.8.1",
    "rimraf": "6.1.3",
    "typescript": "5.9.3",
    "vitest": "4.0.18"
  }
}
