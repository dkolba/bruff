{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "baseUrl": ".",
    "composite": true,
    "paths": {
      "@bruff/utils": ["index.ts"],
      "@bruff/utils/dom": ["dom.ts"],
      "@/*": ["module/*"]
    }
  },
  "include": [
    "dom.ts",
    "index.ts",
    "module/**/**.ts",
    "vitest.config.ts",
    "vitest.node.config.ts"
  ],
  "exclude": ["node_modules", "eslint.config.js"]
}
