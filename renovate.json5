// renovate.json5 — Renovate config for dkolba/bruff
// pnpm monorepo · changesets · minimumReleaseAge · grouped deps
{
  $schema: "https://docs.renovatebot.com/renovate-schema.json",

  // ─── Core behaviour ───────────────────────────────────────────────────────
  extends: [
    "config:recommended", // Renovate's opinionated base
    ":dependencyDashboard", // single tracking issue
    ":separatePatchReleases", // patch PRs are independent from minor/major
    ":semanticCommits", // feat/fix/chore prefixes
    "group:monorepos", // keep monorepo packages in sync automatically
    "group:recommended", // groups well-known companion packages
    "workarounds:all", // apply all upstream-bug workarounds
  ],

  // ─── pnpm ─────────────────────────────────────────────────────────────────
  // Tell Renovate this repo uses pnpm so it reads pnpm-lock.yaml and
  // pnpm-workspace.yaml correctly.
  npmrc: "//registry.npmjs.org/",

  // Renovate natively handles pnpm workspaces; "workspace:*" ranges are kept.
  constraints: {
    pnpm: ">=10",
    node: ">=24",
  },

  // ─── Stability gate ───────────────────────────────────────────────────────
  // Mirror the 4 320-minute (3-day) minimumReleaseAge already set in
  // pnpm-workspace.yaml so no release hits the repo before it has soaked.
  minimumReleaseAge: "3 days",

  // ─── PR hygiene ───────────────────────────────────────────────────────────
  prHourlyLimit: 4, // max PRs opened per hour (burst protection)
  prConcurrentLimit: 10, // max open Renovate PRs at any time
  branchConcurrentLimit: 10, // keep branch list tidy
  rebaseWhen: "behind-base-branch",
  labels: ["dependencies"],

  // ─── Vulnerability alerts ─────────────────────────────────────────────────
  vulnerabilityAlerts: {
    enabled: true,
    minimumReleaseAge: "0 days", // security fixes skip the stability gate
    labels: ["dependencies", "security"],
    addLabels: ["priority: high"],
  },

  // ─── Changesets auto-creation for patch updates ───────────────────────────
  // Renovate can run a post-upgrade command that calls the changesets CLI so
  // every patch dependency bump lands with a proper changeset file, keeping
  // your "changeset version" workflow intact.
  //
  // Requires: allowedCommands must be enabled in the Renovate app / self-hosted
  // config to whitelist "pnpm changeset" (see postUpgradeTasks below).
  postUpgradeTasks: {
    commands: [
      // Generate a patch changeset for every workspace package that depends on
      // the updated package.  The --empty flag prevents errors when nothing
      // changed in a particular workspace package.
      'pnpm exec changeset add --empty --message "chore(deps): bump {{{depName}}} from {{{currentVersion}}} to {{{newVersion}}}"',
    ],
    fileFilters: [
      ".changeset/**", // commit the generated changeset files
    ],
    executionMode: "branch", // run once per branch, not per package
  },

  // ─── Package rules ────────────────────────────────────────────────────────
  packageRules: [
    // 1. Patch updates — auto-merge after CI passes + age gate
    {
      matchUpdateTypes: ["patch"],
      minimumReleaseAge: "3 days",
      automerge: true,
      automergeType: "pr", // merge via PR so the changeset commit is included
      platformAutomerge: true, // use GitHub's native merge queue when available
      addLabels: ["automerge"],
    },

    // 2. Minor updates — open PR, do NOT auto-merge, require human review
    {
      matchUpdateTypes: ["minor"],
      minimumReleaseAge: "7 days",
      automerge: false,
      addLabels: ["update: minor"],
    },

    // 3. Major updates — open PR, require human review, extra age soak
    {
      matchUpdateTypes: ["major"],
      minimumReleaseAge: "14 days",
      automerge: false,
      addLabels: ["update: major"],
      prPriority: -1, // deprioritise so they don't clog the queue
    },

    // 4. Vitest suite — keep all vitest/* packages in lock-step
    //    (@vitest/browser, @vitest/browser-playwright, @vitest/coverage-v8, vitest)
    {
      groupName: "vitest",
      matchPackagePatterns: ["^@vitest/", "^vitest$"],
      matchUpdateTypes: ["patch", "minor", "major"],
    },

    // 5. Playwright suite — keep playwright + @playwright/test + @axe-core/playwright in sync
    {
      groupName: "playwright",
      matchPackagePatterns: [
        "^playwright$",
        "^@playwright/",
        "^@axe-core/playwright$",
      ],
      matchUpdateTypes: ["patch", "minor", "major"],
    },

    // 6. ESLint ecosystem — eslint + all plugins move together
    {
      groupName: "eslint",
      matchPackagePatterns: [
        "^eslint$",
        "^@eslint/",
        "^eslint-plugin-",
        "^typescript-eslint$",
      ],
      matchUpdateTypes: ["patch", "minor", "major"],
    },

    // 7. Vite + related plugins — vite, vite-plugin-dts, vite-plugin-istanbul
    {
      groupName: "vite",
      matchPackagePatterns: ["^vite$", "^vite-plugin-"],
      matchUpdateTypes: ["patch", "minor", "major"],
    },

    // 8. TypeScript — pin minor/major updates for manual review
    {
      matchPackageNames: ["typescript"],
      matchUpdateTypes: ["major", "minor"],
      automerge: false,
      addLabels: ["update: typescript"],
    },

    // 9. Changesets CLI — auto-merge patches, human review for minor/major
    {
      matchPackageNames: ["@changesets/cli"],
      matchUpdateTypes: ["patch"],
      automerge: true,
      platformAutomerge: true,
    },

    // 10. Prettier — patch auto-merge, minor/major need review
    //     (formatting changes can affect the whole codebase)
    {
      matchPackageNames: ["prettier"],
      matchUpdateTypes: ["patch"],
      automerge: true,
    },
    {
      matchPackageNames: ["prettier"],
      matchUpdateTypes: ["minor", "major"],
      automerge: false,
      addLabels: ["update: formatter"],
    },

    // 11. Workspace packages — never update internal workspace:* ranges via Renovate
    {
      matchPackagePatterns: ["^@bruff/"],
      enabled: false,
    },

    // 12. Pin @types/* to patch-only auto-merge
    {
      matchPackagePatterns: ["^@types/"],
      matchUpdateTypes: ["patch", "minor"],
      automerge: true,
      platformAutomerge: true,
    },

    // 13. Lock-file maintenance — run weekly, auto-merge
    {
      matchUpdateTypes: ["lockFileMaintenance"],
      enabled: true,
      schedule: ["before 6am on monday"],
      automerge: true,
      platformAutomerge: true,
      addLabels: ["lockfile"],
    },
  ],

  // ─── Lock-file maintenance ────────────────────────────────────────────────
  lockFileMaintenance: {
    enabled: true,
    schedule: ["before 6am on monday"],
  },

  // ─── Ignore patterns ──────────────────────────────────────────────────────
  // Ignore Renovate's own updates to keep noise low
  ignoreDeps: [],
  ignorePaths: ["**/node_modules/**", "**/.nyc_output/**", "**/dist/**"],
}
