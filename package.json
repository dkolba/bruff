{
  "name": "bruff",
  "version": "0.0.0",
  "private": true,
  "description": "A modern JavaScript/TypeScript roguelike game collection with focus on functional programming patterns and type safety.",
  "keywords": [
    "broughlike",
    "roguelike"
  ],
  "license": "BSD-3-Clause",
  "author": "Duncan Kolba <duncankolba@gmail.com>",
  "contributors": [
    {
      "name": "Duncan Kolba",
      "email": "duncankolba@gmail.com"
    }
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/dkolba/bruff.git"
  },
  "type": "module",
  "scripts": {
    "build": "pnpm -r --parallel run build",
    "changeset:add": "changeset",
    "changeset:version": "changeset version",
    "format": "pnpm run format:ai && pnpm -r --parallel run format",
    "format:ai": "prettier -w .agents AGENTS.md",
    "lint": "pnpm -r --parallel run lint",
    "ok": "pnpm run format && pnpm run lint && pnpm run test && pnpm run typecheck && pnpm run build",
    "start": "pnpm --filter @bruff/arcade run dev",
    "test": "pnpm -r --parallel run test",
    "typecheck": "pnpm -r --parallel run typecheck"
  },
  "devDependencies": {
    "@changesets/cli": "catalog:",
    "prettier": "catalog:"
  },
  "engines": {
    "node": ">=24"
  },
  "packageManager": "pnpm@11.3.0+sha512.2c403d6594527287672b1f7056343a1f7c3634036a67ffabfcc2b3d7595d843768f8787148d1b57cf7956c90606bbd192857c363af19e96d2d0ec9ec5741d215"
}
