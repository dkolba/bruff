{
  "version": "0.0.0",
  "configurations": [
    {
      "name": "Arcade: Vite Dev Server",
      "type": "node",
      "request": "launch",
      "cwd": "${workspaceFolder}/packages/arcade",
      "runtimeExecutable": "pnpm",
      "runtimeArgs": ["run", "dev"],
      "console": "integratedTerminal",
      "skipFiles": ["<node_internals>/**"],
      "env": {
        "NODE_ENV": "development"
      }
    },
    {
      "name": "Arcade: Chrome",
      "type": "chrome",
      "request": "launch",
      "url": "http://localhost:5173",
      "webRoot": "${workspaceFolder}/packages/arcade/src"
    }
  ],
  "compounds": [
    {
      "name": "Arcade: Full Debug",
      "configurations": ["Arcade: Vite Dev Server", "Arcade: Chrome"]
    }
  ]
}
